# Copy to .env and fill in your values
# (do not commit .env to git)

# ── Kiwi Tequila (https://tequila.kiwi.com/portal/login/register)
TEQUILA_API_KEY=

# ── NordVPN service credentials (NOT your account login)
# https://my.nordaccount.com/dashboard/nordvpn/manual-configuration/
NORDVPN_USER=
NORDVPN_PASS=

# ── ntfy token (only if your topic is protected)
NTFY_TOKEN=
